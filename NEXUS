menu_kamera() {
    while true; do
        header
        echo -e "${C}[ KAMERA ]${NC}\n"
        echo -e "  ${G}[1]${NC} Buka kamera + tampilkan di laptop"
        echo -e "  ${G}[2]${NC} Ambil foto ke Desktop"
