menu_file() {
    while true; do
        header
        echo -e "${C}[ FILE MANAGER ]${NC}\n"
        echo -e "  ${G}[1]${NC} Lihat /sdcard"
        echo -e "  ${G}[2]${NC} Lihat folder tertentu"
        echo -e "  ${G}[3]${NC} Kirim file laptop → HP"
        echo -e "  ${G}[4]${NC} Ambil file HP → laptop"
        echo -e "  ${G}[5]${NC} Hapus file di HP"
        echo -e "  ${G}[6]${NC} Buat folder di HP"
        echo -e "  ${G}[7]${NC} Ukuran folder"
        echo -e "  ${G}[8]${NC} Cari file"
        echo -e "  ${C}[9]${NC} ADB Bebas ${Y}← jendela baru${NC}"
        echo -e "  ${R}[0]${NC} Kembali"
        echo ""
        read -rp "Pilih [0-9]: " P
        case "$P" in
            1)  ashell ls -la /sdcard/; lanjut ;;
            2)  read -rp "Path folder: " FP; ashell ls -la "$FP"; lanjut ;;
            3)  read -rp "Path file di laptop: " FS
                read -rp "Tujuan di HP: " FD
                arun push "$FS" "$FD"
                echo -e "${G}[OK] Terkirim.${NC}"; lanjut ;;
            4)  read -rp "Path file di HP: " FH
                arun pull "$FH" "$DESKTOP/"
                echo -e "${G}[OK] Disimpan di $DESKTOP.${NC}"; lanjut ;;
            5)  read -rp "Path file dihapus: " FD
                read -rp "Yakin hapus? (YES): " FK
                [[ "$FK" == "YES" ]] && ashell rm -rf "$FD" && echo -e "${G}[OK] Dihapus.${NC}" || echo -e "${Y}[BATAL]${NC}"
                lanjut ;;
            6)  read -rp "Path folder baru: " FM; ashell mkdir "$FM"; echo -e "${G}[OK] Dibuat.${NC}"; lanjut ;;
            7)  read -rp "Path folder: " FS; ashell du -sh "$FS"; lanjut ;;
            8)  read -rp "Nama file (contoh *.jpg): " FN
                read -rp "Cari di: " FW
                ashell find "$FW" -name "$FN"; lanjut ;;
            9)  adb_bebas_baru "ADB Bebas - File" ;;
            0)  return ;;
        esac
    done
}

