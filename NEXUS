# ============================================================
# KAMERA
# ============================================================
menu_kamera() {
    while true; do
        clear
        echo -e "${GREEN}"
        echo "================================================"
        echo "  KAMERA   [IP: ${HP_IP}]"
        echo -e "================================================${NC}"
        echo ""
        echo "  [1] Buka kamera + tampilkan di laptop"
        echo "  [2] Ambil foto ke Desktop"
        echo "  [3] Rekam video"
        echo "  [8] ADB Bebas"
        echo "  [0] Kembali"
        echo ""
        read -rp "Pilih: " P
        case "$P" in
            1)  adb_run shell am start -a android.media.action.IMAGE_CAPTURE >/dev/null
                scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --no-audio &
                echo -e "${GREEN}[OK] Kamera + layar ditampilkan.${NC}" ; pause ;;
            2)  adb_run shell am start -a android.media.action.IMAGE_CAPTURE >/dev/null
                sleep 2
                adb_run shell input keyevent 27
                sleep 2
                mkdir -p "$DESKTOP/foto_hp"
                adb_run pull /sdcard/DCIM/Camera/ "$DESKTOP/foto_hp/" >/dev/null
                echo -e "${GREEN}[OK] Foto di Desktop/foto_hp.${NC}" ; pause ;;
            3)  adb_run shell am start -a android.media.action.VIDEO_CAPTURE >/dev/null
                sleep 2
                adb_run shell input keyevent 27
                echo "Rekaman dimulai. Tekan Enter untuk berhenti..."
                read -r
                adb_run shell input keyevent 27
                echo -e "${GREEN}[OK] Rekaman selesai.${NC}" ; pause ;;
            8)  adb_bebas_inline ;;
            0)  return ;;
        esac
    done
}

# ============================================================
# MONITOR REAL-TIME
# ============================================================
buka_monitor() {
    echo -e "${CYAN}[INFO] Menjalankan Monitor Real-Time (Ctrl+C untuk berhenti)...${NC}"
    sleep 1
    # Coba buka di terminal baru, jika gagal jalankan di terminal yang sama
    if command -v gnome-terminal &>/dev/null; then
        gnome-terminal -- bash -c "
            while true; do
                clear
                echo '=============================='
                echo \" MONITOR HP - ${HP_IP}\"
                echo \" \$(date)\"
                echo '=============================='
                echo ''
                echo '[BATERAI]'
                adb -s ${HP_IP}:5555 shell dumpsys battery 2>/dev/null | grep level
                echo ''
                echo '[RAM]'
                adb -s ${HP_IP}:5555 shell cat /proc/meminfo 2>/dev/null | grep MemAvailable
                echo ''
                echo '[APP AKTIF]'
                adb -s ${HP_IP}:5555 shell dumpsys window 2>/dev/null | grep mCurrentFocus
                echo ''
                echo '[JARINGAN]'
                adb -s ${HP_IP}:5555 shell getprop gsm.network.type 2>/dev/null
                echo ''
                echo 'Refresh dalam 5 detik... (Ctrl+C untuk berhenti)'
                sleep 5
            done
        " &
    else
        # Jalankan inline jika tidak ada gnome-terminal
        while true; do
            clear
            echo "=============================="
            echo " MONITOR HP - ${HP_IP}"
            echo " $(date)"
            echo "=============================="
            echo ""
            echo "[BATERAI]"
            adb_run shell dumpsys battery 2>/dev/null | grep level
            echo ""
            echo "[RAM]"
            adb_run shell cat /proc/meminfo 2>/dev/null | grep MemAvailable
            echo ""
            echo "[APP AKTIF]"
            adb_run shell dumpsys window 2>/dev/null | grep mCurrentFocus
            echo ""
            echo "Refresh dalam 5 detik... (Ctrl+C untuk berhenti)"
            sleep 5
        done
    fi
    echo -e "${GREEN}[OK] Monitor berjalan di jendela baru.${NC}"
    pause
}

