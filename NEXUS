#!/usr/bin/env bash
# ============================================================
#   KONTROL HP ANDROID v5.0 
#
#   INSTALASI :
#   1. chmod +x kontrol_hp.sh
#   2. sudo cp kontrol_hp.sh /usr/local/bin/kontrol_hp
#   3. Jalankan: kontrol_hp
# ============================================================

HP_IP=""
LOGFILE="$HOME/hp_history.txt"
DESKTOP="$HOME/Desktop"

# Warna terminal
GREEN='\033[0;32m'
CYAN='\033[0;36m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Pastikan adb tersedia
check_adb() {
    if ! command -v adb &> /dev/null; then
        echo -e "${RED}[ERROR] ADB tidak ditemukan. Install dengan:${NC}"
        echo "  sudo apt install adb          (Debian/Ubuntu)"
        echo "  sudo pacman -S android-tools  (Arch)"
        echo "  sudo dnf install android-tools (Fedora)"
        exit 1
    fi
}

adb_run() {
    adb -s "${HP_IP}:5555" "$@"
}

log_action() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOGFILE"
}

pause() {
    echo ""
    read -rp "Tekan Enter untuk melanjutkan..."
}

# ============================================================
# MENU UTAMA
# ============================================================
menu_utama() {
    while true; do
        clear
        echo -e "${GREEN}"
        echo "================================================"
        echo -e "  ${BOLD}KONTROL HP ANDROID v5.0${NC}${GREEN}"
        echo "  IP: ${HP_IP:-[belum terhubung]}"
        echo "================================================"
        echo -e "${NC}"
        echo "  [1]  Hubungkan ke HP"
        echo "  [2]  Layar HP di Laptop"
        echo "  [3]  Daya HP"
        echo "  [4]  Navigasi dan Input"
        echo "  [5]  Audio dan Volume"
        echo "  [6]  Aplikasi"
        echo "  [7]  Kirim Pesan"
        echo "  [8]  File Manager"
        echo "  [9]  Info dan Status HP"
        echo "  [10] Lokasi HP"
        echo "  [11] Notifikasi"
        echo "  [12] Media Player"
        echo "  [13] Kamera"
        echo "  [14] Monitor Real-Time (background)"
        echo "  [15] Logcat Live"
        echo "  [16] ADB Bebas"
        echo "  [17] History Perintah"
        echo "  [18] Putuskan Koneksi"
        echo "  [0]  Keluar"
        echo ""
        read -rp "Pilih menu [0-18]: " PILIHAN
        case "$PILIHAN" in
            1)  menu_hubungkan ;;
            2)  menu_layar ;;
            3)  menu_daya ;;
            4)  menu_navigasi ;;
            5)  menu_audio ;;
            6)  menu_aplikasi ;;
            7)  menu_pesan ;;
            8)  menu_file ;;
            9)  info_hp ;;
            10) menu_lokasi ;;
            11) menu_notifikasi ;;
            12) menu_media ;;
            13) menu_kamera ;;
            14) buka_monitor ;;
            15) buka_logcat ;;
            16) buka_adb ;;
            17) buka_history ;;
            18) putuskan ;;
            0)  keluar ;;
            *)  ;;
        esac
    done
}

# ============================================================
# HUBUNGKAN
# ============================================================
menu_hubungkan() {
    clear
    echo -e "${GREEN}"
    echo "================================================"
    echo "  HUBUNGKAN KE HP"
    echo -e "================================================${NC}"
    echo ""
    read -rp "Masukkan IP Tailscale HP: " IP
    if [[ -z "$IP" ]]; then return; fi
    echo ""
    echo -e "${CYAN}[INFO] Menghubungkan ke ${IP}:5555...${NC}"
    if adb connect "${IP}:5555"; then
        HP_IP="$IP"
        echo -e "${GREEN}[OK] Berhasil terhubung!${NC}"
        log_action "CONNECT $IP"
    else
        echo -e "${RED}[GAGAL] Pastikan Tailscale aktif di HP.${NC}"
    fi
    pause
}

# ============================================================
# LAYAR HP
# ============================================================
menu_layar() {
    while true; do
        clear
        echo -e "${GREEN}"
        echo "================================================"
        echo "  LAYAR HP DI LAPTOP   [IP: ${HP_IP}]"
        echo -e "================================================${NC}"
        echo ""
        echo "  [1] Layar HP - audio di laptop"
        echo "  [2] Layar HP - audio di HP"
        echo "  [3] Layar HP - audio keduanya"
        echo "  [4] Layar HP - tanpa audio"
        echo "  [5] Mode landscape fullscreen"
        echo "  [6] Mode cermin (tidak bisa kontrol)"
        echo "  [7] Matikan tampilan layar"
        echo "  [8] ADB Bebas"
        echo "  [0] Kembali"
        echo ""
        read -rp "Pilih [0-8]: " P
        case "$P" in
            1) scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --audio-codec=aac &
               echo -e "${GREEN}[OK] Layar HP ditampilkan - audio di laptop.${NC}" ; pause ;;
            2) scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --no-audio &
               echo -e "${GREEN}[OK] Layar HP ditampilkan - audio di HP.${NC}" ; pause ;;
            3) scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --audio-codec=aac --audio-output=both &
               echo -e "${GREEN}[OK] Layar HP ditampilkan - audio keduanya.${NC}" ; pause ;;
            4) scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --no-audio &
               echo -e "${GREEN}[OK] Layar HP ditampilkan tanpa audio.${NC}" ; pause ;;
            5) scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --no-audio --fullscreen --orientation=1 &
               echo -e "${GREEN}[OK] Mode landscape aktif.${NC}" ; pause ;;
            6) scrcpy --tcpip="${HP_IP}:5555" --window-title "Layar-HP" --no-audio --no-control &
               echo -e "${GREEN}[OK] Mode cermin aktif.${NC}" ; pause ;;
            7) pkill scrcpy 2>/dev/null
               echo -e "${GREEN}[OK] Tampilan dimatikan.${NC}" ; pause ;;
            8) adb_bebas_inline ;;
            0) return ;;
        esac
    done
}

# ============================================================
# DAYA HP
# ============================================================
menu_daya() {
    while true; do
        clear
        echo -e "${GREEN}"
        echo "================================================"
        echo "  DAYA HP   [IP: ${HP_IP}]"
        echo -e "================================================${NC}"
        echo ""
        echo "  [1] Tidurkan layar (HP tetap nyala)"
        echo "  [2] Nyalakan layar"
        echo "  [3] Kunci layar"
        echo "  [4] Restart HP"
        echo "  [5] MATIKAN HP SEPENUHNYA (2 langkah)"
        echo "  [8] ADB Bebas"
        echo "  [0] Kembali"
        echo ""
        read -rp "Pilih [0-8]: " P
        case "$P" in
            1) adb_run shell input keyevent 223
               echo -e "${GREEN}[OK] Layar dimatikan. HP tetap nyala.${NC}" ; pause ;;
            2) adb_run shell input keyevent 224
               echo -e "${GREEN}[OK] Layar dinyalakan.${NC}" ; pause ;;
            3) adb_run shell input keyevent 276
               echo -e "${GREEN}[OK] Layar dikunci.${NC}" ; pause ;;
            4)
               read -rp "Ketik YES untuk restart HP: " K
               if [[ "${K^^}" == "YES" ]]; then
                   adb_run shell reboot
                   echo -e "${GREEN}[OK] HP restart.${NC}"
               else echo -e "${YELLOW}[BATAL]${NC}"; fi
               pause ;;
            5)
               clear
               echo -e "${RED}  PERINGATAN - HP akan MATI TOTAL${NC}"
               echo ""
               read -rp "LANGKAH 1 - Ketik MATIKAN: " K1
               if [[ "${K1^^}" != "MATIKAN" ]]; then echo -e "${YELLOW}[BATAL]${NC}"; pause; continue; fi
               read -rp "LANGKAH 2 - Ketik YAKIN: " K2
               if [[ "${K2^^}" != "YAKIN" ]]; then echo -e "${YELLOW}[BATAL]${NC}"; pause; continue; fi
               adb_run shell reboot -p
               echo -e "${GREEN}[OK] HP dimatikan.${NC}" ; pause ;;
            8) adb_bebas_inline ;;
            0) return ;;
        esac
    done
}

# ============================================================
# NAVIGASI DAN INPUT
# ============================================================
menu_navigasi() {
    while true; do
        clear
        echo -e "${GREEN}"
        echo "================================================"
        echo "  NAVIGASI DAN INPUT   [IP: ${HP_IP}]"
        echo -e "================================================${NC}"
        echo ""
        echo "  [1] Home              [7]  Scroll atas"
        echo "  [2] Back              [8]  Scroll bawah"
        echo "  [3] Recent Apps       [9]  Scroll kanan"
        echo "  [4] Enter             [10] Scroll kiri"
        echo "  [5] Ketik teks ke HP  [11] Tap koordinat"
        echo "  [6] Screenshot        [12] Swipe kustom"
        echo "  [13] ADB Bebas"
        echo "  [0] Kembali"
        echo ""
        read -rp "Pilih [0-13]: " P
        case "$P" in
            1)  adb_run shell input keyevent 3   ; echo -e "${GREEN}[OK] Home.${NC}"   ; pause ;;
            2)  adb_run shell input keyevent 4   ; echo -e "${GREEN}[OK] Back.${NC}"   ; pause ;;
            3)  adb_run shell input keyevent 187 ; echo -e "${GREEN}[OK] Recent.${NC}" ; pause ;;
            4)  adb_run shell input keyevent 66  ; echo -e "${GREEN}[OK] Enter.${NC}"  ; pause ;;
            5)
                read -rp "Ketik teks: " TEKS
                adb_run shell input text "$TEKS"
                echo -e "${GREEN}[OK] Teks terkirim.${NC}" ; pause ;;
            6)
                echo -e "${CYAN}[INFO] Mengambil screenshot...${NC}"
                adb_run shell screencap -p /sdcard/ss.png
                sleep 2
                mkdir -p "$DESKTOP"
                adb_run pull /sdcard/ss.png "$DESKTOP/screenshot_hp.png"
                if [[ -f "$DESKTOP/screenshot_hp.png" ]]; then
                    echo -e "${GREEN}[OK] Screenshot disimpan di Desktop!${NC}"
                    xdg-open "$DESKTOP/screenshot_hp.png" 2>/dev/null &
                else echo -e "${RED}[GAGAL] Coba lagi.${NC}"; fi
                pause ;;
            7)  adb_run shell input swipe 500 800 500 300 300 ; echo -e "${GREEN}[OK] Scroll atas.${NC}"  ; pause ;;
            8)  adb_run shell input swipe 500 300 500 800 300 ; echo -e "${GREEN}[OK] Scroll bawah.${NC}" ; pause ;;
            9)  adb_run shell input swipe 200 500 800 500 300 ; echo -e "${GREEN}[OK] Scroll kanan.${NC}" ; pause ;;
            10) adb_run shell input swipe 800 500 200 500 300 ; echo -e "${GREEN}[OK] Scroll kiri.${NC}"  ; pause ;;
            11)
                read -rp "X: " NX ; read -rp "Y: " NY
                adb_run shell input tap "$NX" "$NY"
                echo -e "${GREEN}[OK] Tap (${NX},${NY}).${NC}" ; pause ;;
            12)
                read -rp "Dari X: " SX1 ; read -rp "Dari Y: " SY1
                read -rp "Ke X: " SX2   ; read -rp "Ke Y: " SY2
                read -rp "Durasi ms: " SD
                adb_run shell input swipe "$SX1" "$SY1" "$SX2" "$SY2" "$SD"
                echo -e "${GREEN}[OK] Swipe selesai.${NC}" ; pause ;;
            13) adb_bebas_inline ;;
            0)  return ;;
        esac
    done
}

