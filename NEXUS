#!/usr/bin/env bash
# ============================================================
#   NEXUS - KONTROL HP ANDROID v6.0
#   Kompatibel: Kali, Ubuntu, Debian, Parrot, Arch
#
#   INSTALL (1 perintah):
#   curl -fsSL https://raw.githubusercontent.com/troltri7-hue/GII/main/NEXUS \
#     | sudo tee /usr/local/bin/NEXUS > /dev/null \
#     && sudo chmod +x /usr/local/bin/NEXUS
#
#   JALANKAN: NEXUS
# ============================================================

HP_IP=""
LOGFILE="$HOME/hp_history.log"
DESKTOP="$HOME/Desktop"
[[ ! -d "$DESKTOP" ]] && DESKTOP="$HOME"

# ── Warna ──
G='\033[0;32m'   # Hijau
C='\033[0;36m'   # Cyan
R='\033[0;31m'   # Merah
Y='\033[1;33m'   # Kuning
B='\033[0;34m'   # Biru
P='\033[0;35m'   # Ungu
W='\033[1;37m'   # Putih tebal
NC='\033[0m'     # Reset

# ── Cari terminal yang tersedia di sistem ──
cari_terminal() {
    for T in x-terminal-emulator xterm gnome-terminal konsole xfce4-terminal lxterminal qterminal mate-terminal; do
        command -v "$T" &>/dev/null && echo "$T" && return
    done
    echo "none"
}
TERMINAL=$(cari_terminal)

# ── Buka jendela terminal baru ──
buka_terminal() {
    local JUDUL="$1"
    local PERINTAH="$2"
    local TMPFILE
    TMPFILE=$(mktemp /tmp/hp_XXXXXX.sh)
    echo "#!/bin/bash" > "$TMPFILE"
    echo "$PERINTAH" >> "$TMPFILE"
    echo "read -rp 'Tekan Enter untuk tutup...'" >> "$TMPFILE"
    chmod +x "$TMPFILE"

    case "$TERMINAL" in
        x-terminal-emulator) x-terminal-emulator -T "$JUDUL" -e "bash $TMPFILE" & ;;
        xterm)               xterm -title "$JUDUL" -e "bash $TMPFILE" & ;;
        gnome-terminal)      gnome-terminal --title="$JUDUL" -- bash "$TMPFILE" & ;;
        konsole)             konsole --title "$JUDUL" -e bash "$TMPFILE" & ;;
        xfce4-terminal)      xfce4-terminal --title="$JUDUL" -e "bash $TMPFILE" & ;;
        lxterminal)          lxterminal --title="$JUDUL" -e "bash $TMPFILE" & ;;
        qterminal)           qterminal -e "bash $TMPFILE" & ;;
        mate-terminal)       mate-terminal --title="$JUDUL" -e "bash $TMPFILE" & ;;
        none)
            # Fallback: tmux atau inline
            if command -v tmux &>/dev/null && [ -n "$TMUX" ]; then
                tmux new-window -n "$JUDUL" "bash $TMPFILE"
            else
                echo -e "${Y}[INFO] Tidak ada terminal GUI. Membuka di sini.${NC}"
                bash "$TMPFILE"
            fi
            ;;
    esac
    sleep 0.5
}

# ── Cek ADB ──
cek_adb() {
    if ! command -v adb &>/dev/null; then
        echo -e "${R}[ERROR] ADB tidak ditemukan.${NC}"
        echo -e "${Y}Install:${NC}"
        echo "  sudo apt install adb              (Kali/Debian/Ubuntu)"
        echo "  sudo pacman -S android-tools      (Arch)"
        echo "  sudo dnf install android-tools    (Fedora)"
        exit 1
    fi
}

# ── Cek & install scrcpy ──
cek_scrcpy() {
    if ! command -v scrcpy &>/dev/null; then
        echo -e "${Y}[INFO] scrcpy belum terinstall.${NC}"
        read -rp "Install sekarang? (y/n): " INS
        if [[ "${INS,,}" == "y" ]]; then
            sudo apt update -qq && sudo apt install -y scrcpy 2>/dev/null || \
            sudo snap install scrcpy 2>/dev/null || \
            echo -e "${R}[GAGAL] Install manual: https://github.com/Genymobile/scrcpy/releases${NC}"
        fi
    fi
}

# ── ADB helper ──
arun() { adb -s "${HP_IP}:5555" "$@"; }
ashell() { adb -s "${HP_IP}:5555" shell "$@"; }

# ── Log ──
log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOGFILE"; }

# ── Lanjut ──
lanjut() { echo -e "\n${C}Tekan Enter untuk kembali...${NC}"; read -r; }

# ── Header ──
header() {
    clear
    echo -e "${P}================================================${NC}"
    echo -e "${W}  NEXUS - KONTROL HP ANDROID v6.0${NC}"
    echo -e "${C}  Terminal: ${Y}$TERMINAL${NC}"
    echo -e "${C}  IP HP   : ${Y}${HP_IP:-[belum terhubung]}${NC}"
    echo -e "${P}================================================${NC}"
    echo ""
}

# ── ADB Bebas loop (bisa di jendela ini atau baru) ──
adb_bebas_loop() {
    local JUDUL="${1:-ADB Bebas}"
    echo -e "${B}=============================="
    echo -e "  $JUDUL - $HP_IP"
    echo -e "  Ketik 'exit' untuk kembali"
    echo -e "==============================${NC}"
    echo ""
    while true; do
        read -rp "$(echo -e "${G}adb shell \$ ${NC}")" CMD
        [[ "${CMD,,}" == "exit" || "${CMD,,}" == "quit" ]] && break
        [[ -z "$CMD" ]] && continue
        log "ADB: $CMD"
        adb -s "${HP_IP}:5555" shell $CMD
        echo ""
    done
}

# ── ADB Bebas di jendela baru ──
adb_bebas_baru() {
    local JUDUL="${1:-ADB Bebas}"
    local CMD_BLOK
    CMD_BLOK=$(cat << INNEREOF
echo -e '\033[0;34m=============================='
echo "  $JUDUL"
echo "  IP: $HP_IP"
echo "  Ketik exit untuk tutup"
echo -e '==============================\033[0m'
echo ""
while true; do
    read -rp "\$(echo -e '\033[0;32madb shell \$ \033[0m')" CMD
    [[ "\${CMD,,}" == "exit" || "\${CMD,,}" == "quit" ]] && break
    [[ -z "\$CMD" ]] && continue
    adb -s "${HP_IP}:5555" shell \$CMD
    echo ""
done
INNEREOF
)
    buka_terminal "$JUDUL" "$CMD_BLOK"
    echo -e "${G}[OK] Jendela '$JUDUL' dibuka ($TERMINAL).${NC}"
    lanjut
}

