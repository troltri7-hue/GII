                scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --no-audio &>/dev/null &
                echo -e "${G}[OK] Kamera + layar ditampilkan.${NC}"; lanjut ;;
            2)  ashell am start -a android.media.action.IMAGE_CAPTURE &>/dev/null
                sleep 2; ashell input keyevent 27; sleep 2
                mkdir -p "$DESKTOP/foto_hp"
                arun pull /sdcard/DCIM/Camera/ "$DESKTOP/foto_hp/" &>/dev/null
                echo -e "${G}[OK] Foto disimpan di $DESKTOP/foto_hp.${NC}"; lanjut ;;
            3)  ashell am start -a android.media.action.VIDEO_CAPTURE &>/dev/null
                sleep 2; ashell input keyevent 27
                echo -e "${Y}Rekaman dimulai. Tekan Enter untuk berhenti...${NC}"; read -r
