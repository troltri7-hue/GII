# ============================================================
# KIRIM PESAN
# ============================================================
menu_pesan() {
    while true; do
        clear
        echo -e "${GREEN}"
        echo "================================================"
        echo "  KIRIM PESAN   [IP: ${HP_IP}]"
        echo -e "================================================${NC}"
        echo ""
        echo "  [1] WhatsApp (langsung terkirim)"
        echo "  [2] SMS (langsung terkirim)"
        echo "  [3] Telegram (langsung terkirim)"
        echo "  [4] Telepon nomor"
        echo "  [8] ADB Bebas"
        echo "  [0] Kembali"
        echo ""
        read -rp "Pilih [0-8]: " P
        case "$P" in
            1)  read -rp "Nomor WA (628xxx): " NOWA
                read -rp "Isi pesan: " PESANWA
                adb_run shell am start -a android.intent.action.VIEW -d "https://api.whatsapp.com/send?phone=${NOWA}&text=${PESANWA}"
                sleep 4 && adb_run shell input keyevent 66
                echo -e "${GREEN}[OK] WA terkirim.${NC}" ; pause ;;
            2)  read -rp "Nomor SMS: " NOSMS
                read -rp "Isi pesan: " ISISMS
                adb_run shell am start -a android.intent.action.SENDTO -d "smsto:${NOSMS}" --es sms_body "$ISISMS" --ez exit_on_sent true
                sleep 4 && adb_run shell input keyevent 66
                echo -e "${GREEN}[OK] SMS terkirim.${NC}" ; pause ;;
            3)  read -rp "Username Telegram (tanpa @): " USERTG
                read -rp "Isi pesan: " ISITG
                adb_run shell am start -a android.intent.action.VIEW -d "tg://resolve?domain=${USERTG}&text=${ISITG}"
                sleep 4 && adb_run shell input keyevent 66
                echo -e "${GREEN}[OK] TG terkirim.${NC}" ; pause ;;
            4)  read -rp "Nomor: " NOTELP
                adb_run shell am start -a android.intent.action.CALL -d "tel:${NOTELP}"
                echo -e "${GREEN}[OK] Menelepon.${NC}" ; pause ;;
            8)  adb_bebas_inline ;;
            0)  return ;;
        esac
    done
}

# ============================================================
# FILE MANAGER
# ============================================================
menu_file() {
    while true; do
        clear
        echo -e "${GREEN}"
        echo "================================================"
        echo "  FILE MANAGER   [IP: ${HP_IP}]"
        echo -e "================================================${NC}"
        echo ""
        echo "  [1] Lihat /sdcard"
        echo "  [2] Lihat folder tertentu"
        echo "  [3] Kirim file laptop ke HP"
        echo "  [4] Ambil file HP ke Desktop"
        echo "  [5] Hapus file di HP"
        echo "  [6] Buat folder di HP"
        echo "  [7] Ukuran folder"
        echo "  [8] Cari file"
        echo "  [9] ADB Bebas"
        echo "  [0] Kembali"
        echo ""
        read -rp "Pilih [0-9]: " P
        case "$P" in
            1)  adb_run shell ls -la /sdcard/ ; pause ;;
            2)  read -rp "Path folder: " FP ; adb_run shell ls -la "$FP" ; pause ;;
            3)  read -rp "Path file di laptop: " FS
                read -rp "Tujuan di HP: " FD
                adb_run push "$FS" "$FD"
                echo -e "${GREEN}[OK] Terkirim.${NC}" ; pause ;;
            4)  read -rp "Path file di HP: " FH
                mkdir -p "$DESKTOP"
                adb_run pull "$FH" "$DESKTOP/"
                echo -e "${GREEN}[OK] Disimpan di Desktop.${NC}" ; pause ;;
            5)  read -rp "Path file dihapus: " FD
                read -rp "Yakin? (YES): " FK
                if [[ "${FK^^}" == "YES" ]]; then
                    adb_run shell rm -rf "$FD"
                    echo -e "${GREEN}[OK] Dihapus.${NC}"
                else echo -e "${YELLOW}[BATAL]${NC}"; fi
                pause ;;
            6)  read -rp "Nama folder baru: " FM
                adb_run shell mkdir "$FM"
                echo -e "${GREEN}[OK] Folder dibuat.${NC}" ; pause ;;
            7)  read -rp "Path folder: " FS ; adb_run shell du -sh "$FS" ; pause ;;
            8)  read -rp "Nama file (contoh *.jpg): " FN
                read -rp "Cari di: " FW
                adb_run shell find "$FW" -name "$FN" ; pause ;;
            9)  adb_bebas_inline ;;
            0)  return ;;
        esac
    done
}

# ============================================================
# INFO HP
# ============================================================
info_hp() {
    clear
    echo -e "${GREEN}"
    echo "================================================"
    echo "  INFO HP   [IP: ${HP_IP}]"
    echo -e "================================================${NC}"
    echo ""
    MODEL=$(adb_run shell getprop ro.product.model 2>/dev/null | tr -d '\r')
    ANDROID=$(adb_run shell getprop ro.build.version.release 2>/dev/null | tr -d '\r')
    echo "Model    : $MODEL"
    echo "Android  : $ANDROID"
    echo ""
    echo "--- BATERAI ---"
    adb_run shell dumpsys battery | grep -i "level\|status\|temperature"
    echo ""
    echo "--- RAM ---"
    adb_run shell cat /proc/meminfo | grep -i "MemTotal\|MemFree\|MemAvailable"
    echo ""
    echo "--- STORAGE ---"
    adb_run shell df /sdcard
    echo ""
    echo "--- JARINGAN ---"
    adb_run shell getprop gsm.operator.alpha
    adb_run shell getprop gsm.network.type
    echo ""
    echo "--- APP AKTIF ---"
    adb_run shell dumpsys window 2>/dev/null | grep "mCurrentFocus"
    echo ""
    pause
}

# ============================================================
# LOKASI HP
# ============================================================
menu_lokasi() {
    while true; do
        clear
        echo -e "${GREEN}"
        echo "================================================"
        echo "  LOKASI HP   [IP: ${HP_IP}]"
        echo -e "================================================${NC}"
        echo ""
        adb_run shell dumpsys location 2>/dev/null | grep -i "last known"
        echo ""
        echo "  [1] Buka android.com/find"
        echo "  [2] Aktifkan GPS"
        echo "  [3] Matikan GPS"
        echo "  [8] ADB Bebas"
        echo "  [0] Kembali"
        echo ""
        read -rp "Pilih: " P
        case "$P" in
            1) xdg-open "https://android.com/find" 2>/dev/null & ;;
            2) adb_run shell settings put secure location_mode 3 ; echo -e "${GREEN}[OK] GPS aktif.${NC}" ; pause ;;
            3) adb_run shell settings put secure location_mode 0 ; echo -e "${GREEN}[OK] GPS mati.${NC}"  ; pause ;;
            8) adb_bebas_inline ;;
            0) return ;;
        esac
    done
}

