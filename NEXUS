buka_monitor() {
    local CMD_BLOK
    CMD_BLOK=$(cat << MONEOF
while true; do
    clear
    echo -e '\033[0;35m=============================='
    echo "  MONITOR HP - $HP_IP"
    echo "  \$(date '+%Y-%m-%d %H:%M:%S')"
    echo -e '==============================\033[0m'
    echo ""
    echo -e '\033[1;33m[BATERAI]\033[0m'
    adb -s ${HP_IP}:5555 shell dumpsys battery 2>/dev/null | grep -i "level\|status\|temperature"
    echo ""
    echo -e '\033[1;33m[RAM]\033[0m'
    adb -s ${HP_IP}:5555 shell cat /proc/meminfo 2>/dev/null | grep -i "MemAvailable\|MemTotal"
    echo ""
    echo -e '\033[1;33m[APP AKTIF]\033[0m'
    adb -s ${HP_IP}:5555 shell dumpsys window 2>/dev/null | grep mCurrentFocus
    echo ""
    echo -e '\033[1;33m[JARINGAN]\033[0m'
    adb -s ${HP_IP}:5555 shell getprop gsm.network.type 2>/dev/null
    adb -s ${HP_IP}:5555 shell getprop gsm.operator.alpha 2>/dev/null
    echo ""
    echo -e '\033[0;36mRefresh tiap 5 detik... Ctrl+C untuk tutup\033[0m'
    sleep 5
done
MONEOF
)
    buka_terminal "Monitor HP Real-Time" "$CMD_BLOK"
    echo -e "${G}[OK] Jendela Monitor dibuka ($TERMINAL).${NC}"
    lanjut
}

buka_logcat() {
    local CMD_BLOK
    CMD_BLOK=$(cat << LOGEOF
echo -e '\033[0;36m=============================='
echo "  LOGCAT LIVE - $HP_IP"
echo "  Ctrl+C untuk berhenti"
echo -e '==============================\033[0m'
echo ""
adb -s ${HP_IP}:5555 logcat -s NotificationService:D ActivityManager:I '*:E'
LOGEOF
)
    buka_terminal "Logcat Live HP" "$CMD_BLOK"
    echo -e "${G}[OK] Jendela Logcat dibuka ($TERMINAL).${NC}"
    lanjut
}

buka_history() {
    if [[ ! -f "$LOGFILE" ]]; then
        echo -e "${Y}Belum ada history.${NC}"; lanjut; return
    fi
    local CMD_BLOK
    CMD_BLOK=$(cat << HISTEOF
echo -e '\033[0;36m=============================='
echo '  HISTORY PERINTAH'
echo -e '==============================\033[0m'
echo ""
cat $LOGFILE
echo ""
HISTEOF
)
    buka_terminal "History Perintah" "$CMD_BLOK"
    echo -e "${G}[OK] Jendela History dibuka ($TERMINAL).${NC}"
    lanjut
}

putuskan() {
    adb disconnect
    HP_IP=""
    echo -e "${G}[OK] Koneksi diputuskan.${NC}"
    log "DISCONNECT"
    lanjut
}

# ============================================================
# INSTALL DEPENDENCIES
# ============================================================
install_deps() {
    echo -e "${C}[INFO] Mengecek dan menginstall dependencies...${NC}"
    # ADB
    if ! command -v adb &>/dev/null; then
        echo -e "${Y}Install ADB...${NC}"
        sudo apt install -y adb 2>/dev/null || sudo pacman -S --noconfirm android-tools 2>/dev/null
    fi
    # scrcpy
    if ! command -v scrcpy &>/dev/null; then
        echo -e "${Y}Install scrcpy...${NC}"
        sudo apt install -y scrcpy 2>/dev/null || sudo snap install scrcpy 2>/dev/null
    fi
    # Terminal emulator fallback
    if [[ "$TERMINAL" == "none" ]]; then
        echo -e "${Y}Install xterm sebagai terminal fallback...${NC}"
        sudo apt install -y xterm 2>/dev/null
        TERMINAL=$(cari_terminal)
    fi
    echo -e "${G}[OK] Semua dependencies siap.${NC}"
    echo -e "${C}Terminal yang digunakan: $TERMINAL${NC}"
    lanjut
}

# ============================================================
# ENTRY POINT
# ============================================================
# Cek argumen
case "${1:-}" in
    --install) install_deps; exit 0 ;;
    --help)
        echo "Penggunaan: NEXUS [opsi]"
        echo "  (tanpa opsi)  : Jalankan program"
        echo "  --install     : Install semua dependencies"
        echo "  --help        : Tampilkan bantuan ini"
        echo ""
        echo "Install global (akses dari mana saja):"
        echo "  curl -fsSL https://raw.githubusercontent.com/troltri7-hue/GII/main/NEXUS | sudo tee /usr/local/bin/NEXUS > /dev/null"
        echo "  sudo chmod +x /usr/local/bin/NEXUS"
        echo "  NEXUS"
        exit 0 ;;
esac

