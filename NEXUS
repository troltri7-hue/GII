info_hp() {
    header
    echo -e "${C}[ INFO DAN STATUS HP ]${NC}\n"
    echo -e "${Y}--- MODEL ---${NC}"
    ashell getprop ro.product.model
    ashell getprop ro.build.version.release
    echo -e "\n${Y}--- BATERAI ---${NC}"
    ashell dumpsys battery | grep -i "level\|status\|temperature"
    echo -e "\n${Y}--- RAM ---${NC}"
    ashell cat /proc/meminfo | grep -i "MemTotal\|MemFree\|MemAvailable"
    echo -e "\n${Y}--- STORAGE ---${NC}"
    ashell df /sdcard
    echo -e "\n${Y}--- JARINGAN ---${NC}"
    ashell getprop gsm.operator.alpha
    ashell getprop gsm.network.type
    echo -e "\n${Y}--- RESOLUSI ---${NC}"
    ashell wm size
    echo -e "\n${Y}--- APP AKTIF ---${NC}"
    ashell dumpsys window | grep mCurrentFocus
    echo ""
    read -rp "[8] ADB Bebas (jendela baru)  [0] Kembali: " P
    [[ "$P" == "8" ]] && adb_bebas_baru "ADB Bebas - Info"
}

