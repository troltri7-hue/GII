    pause
}

# ============================================================
# ADB BEBAS (inline)
# ============================================================
adb_bebas_inline() {
    clear
    echo -e "${BLUE}"
    echo "=============================="
    echo "  ADB BEBAS - ${HP_IP}"
    echo "  Ketik 'exit' untuk kembali"
    echo -e "==============================${NC}"
    echo ""
    while true; do
        read -rp "adb shell \$ " CMD
        [[ "${CMD,,}" == "exit" || -z "$CMD" ]] && break
        adb_run shell "$CMD"
        echo ""
    done
}

buka_adb() {
    adb_bebas_inline
}

# ============================================================
# HISTORY
# ============================================================
buka_history() {
    clear
    echo -e "${GREEN}"
    echo "=============================="
    echo "  HISTORY PERINTAH"
    echo -e "==============================${NC}"
    echo ""
    if [[ ! -f "$LOGFILE" ]]; then
        echo "Belum ada history."
    else
        cat "$LOGFILE"
    fi
    echo ""
    pause
}

