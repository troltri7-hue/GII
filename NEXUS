        echo -e "================================================${NC}"
        echo ""
        echo "  [1] Kirim notifikasi ke HP"
        echo "  [2] Buka panel notifikasi"
        echo "  [3] Tutup panel notifikasi"
        echo "  [8] ADB Bebas"
        echo "  [0] Kembali"
        echo ""
        read -rp "Pilih: " P
        case "$P" in
            1)  read -rp "Judul: " NTITLE
                read -rp "Isi: " NBODY
                adb_run shell cmd notification post -S bigtext -t "$NTITLE" Tag "$NBODY"
                echo -e "${GREEN}[OK] Notifikasi terkirim.${NC}" ; pause ;;
            2)  adb_run shell cmd statusbar expand-notifications ; echo -e "${GREEN}[OK] Panel dibuka.${NC}"  ; pause ;;
            3)  adb_run shell cmd statusbar collapse             ; echo -e "${GREEN}[OK] Panel ditutup.${NC}" ; pause ;;
            8)  adb_bebas_inline ;;
            0)  return ;;
        esac
    done
}

