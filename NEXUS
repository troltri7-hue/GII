            2)  read -rp "Nomor SMS: " NOSMS
                read -rp "Isi pesan: " ISISMS
                ashell am start -a android.intent.action.SENDTO -d "smsto:$NOSMS" --es sms_body "$ISISMS" --ez exit_on_sent true
                sleep 4; ashell input keyevent 66
                echo -e "${G}[OK] SMS terkirim.${NC}"; lanjut ;;
            3)  read -rp "Username Telegram (tanpa @): " USERTG
                read -rp "Isi pesan: " ISITG
                ashell am start -a android.intent.action.VIEW -d "tg://resolve?domain=$USERTG&text=$ISITG"
                sleep 4; ashell input keyevent 66
                echo -e "${G}[OK] TG terkirim.${NC}"; lanjut ;;
            4)  read -rp "Nomor: " NOTELP
                ashell am start -a android.intent.action.CALL -d "tel:$NOTELP"
                echo -e "${G}[OK] Menelepon.${NC}"; lanjut ;;
            8)  adb_bebas_baru "ADB Bebas - Pesan" ;;
            0)  return ;;
        esac
    done
}

