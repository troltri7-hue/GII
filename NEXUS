# ============================================================
menu_hubungkan() {
    header
    echo -e "${C}[ HUBUNGKAN KE HP ]${NC}\n"
    read -rp "Masukkan IP Tailscale HP (contoh: 100.xx.xx.xx): " IP
    [[ -z "$IP" ]] && return
    echo -e "\n${Y}[INFO] Menghubungkan ke $IP:5555...${NC}"
    OUT=$(adb connect "$IP:5555" 2>&1)
    echo "$OUT"
    if echo "$OUT" | grep -qi "connected"; then
        HP_IP="$IP"
        echo -e "${G}[OK] Berhasil terhubung!${NC}"
        log "CONNECT $IP OK"
    else
        echo -e "${R}[GAGAL] Pastikan Tailscale aktif dan USB Debugging ON.${NC}"
        echo -e "${Y}Coba: adb kill-server && adb start-server${NC}"
    fi
    lanjut
}

# ============================================================
menu_layar() {
    # Pastikan DISPLAY tersedia untuk scrcpy
    if [[ -z "$DISPLAY" && -z "$WAYLAND_DISPLAY" ]]; then
        export DISPLAY=:0
    fi
    while true; do
        header
        echo -e "${C}[ LAYAR HP DI LAPTOP ]${NC}\n"
        echo -e "  ${G}[1]${NC} Tampilkan layar - audio di laptop"
        echo -e "  ${G}[2]${NC} Tampilkan layar - audio di HP"
        echo -e "  ${G}[3]${NC} Tampilkan layar - audio keduanya"
        echo -e "  ${G}[4]${NC} Tampilkan layar - tanpa audio"
        echo -e "  ${G}[5]${NC} Mode landscape fullscreen"
        echo -e "  ${G}[6]${NC} Mode cermin (tidak bisa kontrol)"
        echo -e "  ${G}[7]${NC} Matikan tampilan layar"
        echo -e "  ${C}[8]${NC} ADB Bebas ${Y}← jendela baru${NC}"
        echo -e "  ${R}[0]${NC} Kembali"
        echo ""
        read -rp "Pilih [0-8]: " P
        case "$P" in
            1) scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --audio-codec=aac &>/dev/null &
               echo -e "${G}[OK] Layar HP ditampilkan - audio di laptop.${NC}"; lanjut ;;
            2) scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --no-audio &>/dev/null &
               echo -e "${G}[OK] Layar HP ditampilkan - audio di HP.${NC}"; lanjut ;;
            3) scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --audio-codec=aac --audio-output=both &>/dev/null &
               echo -e "${G}[OK] Audio keduanya.${NC}"; lanjut ;;
            4) scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --no-audio &>/dev/null &
               echo -e "${G}[OK] Tanpa audio.${NC}"; lanjut ;;
            5) scrcpy --tcpip="${HP_IP}:5555" --stay-awake --window-title "Layar-HP" --no-audio --fullscreen --orientation=1 &>/dev/null &
               echo -e "${G}[OK] Landscape.${NC}"; lanjut ;;
            6) scrcpy --tcpip="${HP_IP}:5555" --window-title "Layar-HP" --no-audio --no-control &>/dev/null &
               echo -e "${G}[OK] Mode cermin.${NC}"; lanjut ;;
            7) pkill -f scrcpy 2>/dev/null; echo -e "${G}[OK] Tampilan dimatikan.${NC}"; lanjut ;;
            8) adb_bebas_baru "ADB Bebas - Layar" ;;
            0) return ;;
        esac
    done
}

# ============================================================
menu_daya() {
    while true; do
        header
        echo -e "${C}[ DAYA HP ]${NC}\n"
        echo -e "  ${G}[1]${NC} Tidurkan layar (HP tetap nyala)"
        echo -e "  ${G}[2]${NC} Nyalakan layar"
        echo -e "  ${G}[3]${NC} Kunci layar"
        echo -e "  ${G}[4]${NC} Restart HP"
        echo -e "  ${R}[5]${NC} MATIKAN HP SEPENUHNYA (2 langkah)"
        echo -e "  ${C}[8]${NC} ADB Bebas ${Y}← jendela baru${NC}"
        echo -e "  ${R}[0]${NC} Kembali"
        echo ""
        read -rp "Pilih [0-8]: " P
        case "$P" in
            1) ashell input keyevent 223; echo -e "${G}[OK] Layar dimatikan. HP tetap nyala.${NC}"; lanjut ;;
            2) ashell input keyevent 224; echo -e "${G}[OK] Layar dinyalakan.${NC}"; lanjut ;;
            3) ashell input keyevent 276; echo -e "${G}[OK] Layar dikunci.${NC}"; lanjut ;;
            4) read -rp "Ketik YES untuk restart: " K
               [[ "${K^^}" == "YES" ]] && ashell reboot && echo -e "${G}[OK] HP restart.${NC}" || echo -e "${Y}[BATAL]${NC}"
               lanjut ;;
            5) echo -e "\n${R}PERINGATAN - HP akan MATI TOTAL${NC}"
               read -rp "LANGKAH 1 - Ketik MATIKAN: " K1
               [[ "${K1^^}" != "MATIKAN" ]] && echo -e "${Y}[BATAL]${NC}" && lanjut && continue
               read -rp "LANGKAH 2 - Ketik YAKIN: " K2
               [[ "${K2^^}" != "YAKIN" ]] && echo -e "${Y}[BATAL]${NC}" && lanjut && continue
               ashell reboot -p; echo -e "${G}[OK] HP dimatikan.${NC}"; lanjut ;;
            8) adb_bebas_baru "ADB Bebas - Daya" ;;
            0) return ;;
        esac
    done
}

